TZ=UTC
PORT=3334
HOST=0.0.0.0
LOG_LEVEL=error
APP_KEY=test-app-key-min-16-chars-long-here
APP_NAME=patissio-test
NODE_ENV=test
API_PUBLIC_URL=http://localhost:3334

# Test database (must exist before running tests)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/patisserie_test

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6380
REDIS_PASSWORD=

# Session
SESSION_DRIVER=cookie

# Mail (required by env schema but not used in tests)
MAIL_FROM=test@patissio.test

# Disable external services in tests
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
TURNSTILE_SECRET_KEY=
TURNSTILE_SITE_KEY=
SENTRY_DSN=

# Storage
DRIVE_DISK=r2
R2_KEY=minioadmin
R2_SECRET=minioadmin
R2_REGION=auto
R2_BUCKET=patisserie-private-test
R2_PUBLIC_BUCKET=patisserie-public-test
R2_ENDPOINT=http://localhost:9002
R2_PUBLIC_URL=http://localhost:9002/patisserie-public-test

# Frontend URLs
FRONTEND_URL=http://localhost:3000
SUPERADMIN_URL=http://localhost:3001
